@page "/login"
@layout AuthLayout
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavManager
@inject NutritionAdvisor.Client.Auth.CookieAuthStateProvider AuthStateProvider

<div class="auth-wrapper">

    <div class="auth-card">

        <h2 class="auth-title">Welcome Back</h2>
        <p class="auth-subtitle">Sign in to continue</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger text-center">
                @errorMessage
            </div>
        }

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <ValidationMessage For="@(() => loginModel.Email)" />
                <InputText
                    class="form-control-custom"
                    placeholder="Email"
                    type="email"
                    @bind-Value="loginModel.Email"/>
            </div>

            <div class="form-group">
                <ValidationMessage For="@(() => loginModel.Password)" />
                <InputText
                    class="form-control-custom"
                    placeholder="Password"
                    type="password"
                    @bind-Value="loginModel.Password"/>
            </div>

            <button type="submit" class="btn-auth" disabled="@isLoading">

                @if(isLoading)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <span>Sign In</span>
                }

            </button>

        </EditForm>

        <div class="auth-links">
            Don't have an account?
            <a href="/register">Register</a>
        </div>

    </div>

</div>

@code {

private LoginModel loginModel = new();
private bool isLoading;
private string errorMessage = "";

private async Task HandleLogin()
{
    isLoading = true;
    errorMessage = "";

    var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

    if(response.IsSuccessStatusCode)
    {
        AuthStateProvider.NotifyUserAuthentication();
        NavManager.NavigateTo("https://www.google.com/");
    }
    else
    {
        errorMessage = await response.Content.ReadAsStringAsync();
    }

    isLoading = false;
}
public class LoginModel
{
    [Required(ErrorMessage = "Email is required")]
    [EmailAddress(ErrorMessage = "Invalid email")]
    public string Email {get;set;} = "";
    
    [Required(ErrorMessage = "Password is required")]
    public string Password {get;set;} = "";
}

}